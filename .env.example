# Inference Scaffold Environment Variables
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# Provider API Keys
# =============================================================================

# OpenRouter API key (required for openrouter provider – free tier: 50 RPD / 20 RPM)
# Get your key at: https://openrouter.ai/keys
# Free models: https://openrouter.ai/models?fmt=cards&max_price=0&output_modalities=text&input_modalities=text
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# Mock API key (TEST ONLY – not required for real API calls)
# Used for local testing and running examples without an OpenRouter key
MOCK_API_KEY=mock-key-placeholder

# =============================================================================
# Optional Configuration
# =============================================================================

# Default provider when not specified (optional)
# INFERENCE_DEFAULT_PROVIDER=openrouter

# Log level for the inference library (optional)
# INFERENCE_LOG_LEVEL=INFO
