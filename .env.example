# Inference Scaffold Environment Variables
# Copy this file to .env and fill in your actual API keys

# =============================================================================
# Provider API Keys (required for runtime usage)
# =============================================================================

# OpenAI API key (required for openai provider)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API key (required for anthropic provider)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# OpenRouter API key (required for openrouter provider)
# Get your key at: https://openrouter.ai/keys
19#YT|
JB|# Mock API key (TEST ONLY - not required, placeholder only)
JB|# Used for local testing without real API calls
JB|MOCK_API_KEY=mock-key-placeholder
YT|
# =============================================================================
# Optional Configuration
# =============================================================================

# Default provider to use when not specified (optional)
# Options: openai, anthropic, openrouter, mock
# INFERENCE_DEFAULT_PROVIDER=openai

# Log level for the inference library (optional)
# Options: DEBUG, INFO, WARNING, ERROR
# INFERENCE_LOG_LEVEL=INFO
